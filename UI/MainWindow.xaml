<Window x:Class="ScreenClipTool.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TimeCap"
        Width="900" Height="780" MinWidth="720" MinHeight="560"
        Background="#17181D" Foreground="#E9EAEE"
        FontFamily="Segoe UI" FontSize="13"
        WindowStartupLocation="CenterScreen">
  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Theme.xaml"/>
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <DockPanel Margin="18">

    <!-- En-tête : marque + actions -->
    <Grid DockPanel.Dock="Top">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel VerticalAlignment="Center">
        <TextBlock FontSize="22" FontWeight="Bold"><Run Text="TIME" Foreground="#E9EAEE"/><Run Text="CAP" Foreground="#2F6BE4"/></TextBlock>
        <TextBlock Text="C L I P   T H E   M O M E N T" FontSize="9" Foreground="#9BA0AC" Margin="1,2,0,0"/>
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
        <Button Content="Dossier des clips" Click="OpenClipsFolder_Click"/>
        <Button Content="Réglages…" Margin="8,0,0,0" Click="OpenSettings_Click"/>
      </StackPanel>
    </Grid>

    <!-- Statut -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,14,0,0">
      <Ellipse x:Name="StatusDot" Width="12" Height="12" Fill="#5A5E6B" VerticalAlignment="Center"/>
      <TextBlock x:Name="StatusText" Text="Démarrage…" FontSize="15" FontWeight="SemiBold"
                 Margin="9,0,0,0" VerticalAlignment="Center"/>
    </StackPanel>

    <!-- Buffer circulaire -->
    <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Margin="0,12,0,0">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="HISTORIQUE ENREGISTRÉ" Style="{StaticResource CardTitle}"/>
        <TextBlock x:Name="BufferText" Grid.Column="1" Foreground="#9BA0AC" Text="—"/>
        <ProgressBar x:Name="BufferBar" Grid.Row="1" Grid.ColumnSpan="2" Height="10"
                     Margin="0,10,0,0" Minimum="0" Maximum="900"/>
      </Grid>
    </Border>

    <!-- Sauvegarde de clips -->
    <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Margin="0,12,0,0">
      <StackPanel>
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBlock Text="SAUVEGARDER UN CLIP" Style="{StaticResource CardTitle}"/>
          <TextBlock x:Name="GranularityHint" Grid.Column="1" Foreground="#9BA0AC"/>
        </Grid>
        <WrapPanel x:Name="SaveButtons" Margin="0,10,0,0"/>
      </StackPanel>
    </Border>

    <!-- Clips récents -->
    <Border Style="{StaticResource Card}" Margin="0,12,0,0">
      <DockPanel>
        <Grid DockPanel.Dock="Top">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBlock Text="CLIPS RÉCENTS" Style="{StaticResource CardTitle}" VerticalAlignment="Center"/>
          <StackPanel Grid.Column="1" Orientation="Horizontal">
            <Button Content="Lire" Click="Play_Click"/>
            <Button Content="Ouvrir l'emplacement" Margin="8,0,0,0" Click="RevealClip_Click"/>
          </StackPanel>
        </Grid>
        <Grid Margin="0,10,0,0">
          <ListBox x:Name="ClipsList" Background="Transparent" BorderThickness="0"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                   MouseDoubleClick="ClipsList_MouseDoubleClick">
            <ListBox.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel/>
              </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Width="368">
                  <Grid Height="207">
                    <Border CornerRadius="8" Background="#14151A"/>
                    <!-- Pictogramme visible tant que la miniature n'est pas prête -->
                    <Path Data="M0,0 L14,9 L0,18 Z" Fill="#3A3D4A" Width="34" Height="42"
                          Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Rectangle RadiusX="8" RadiusY="8">
                      <Rectangle.Fill>
                        <ImageBrush ImageSource="{Binding Thumbnail}" Stretch="UniformToFill"/>
                      </Rectangle.Fill>
                    </Rectangle>
                  </Grid>
                  <TextBlock Text="{Binding Name}" Margin="2,8,2,0" FontSize="13"
                             TextTrimming="CharacterEllipsis" ToolTip="{Binding Name}"/>
                  <TextBlock Text="{Binding Meta}" Margin="2,2,2,0" FontSize="11.5" Foreground="#9BA0AC"/>
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
          <TextBlock x:Name="ClipsEmptyText" Foreground="#9BA0AC" TextWrapping="Wrap"
                     TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center"
                     Margin="24" Visibility="Collapsed"
                     Text="Aucun clip pour le moment — pressez un raccourci (ou un bouton ci-dessus) pour sauvegarder les dernières secondes."/>
        </Grid>
      </DockPanel>
    </Border>

  </DockPanel>
</Window>
