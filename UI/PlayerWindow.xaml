<Window x:Class="ScreenClipTool.UI.PlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TimeCap — Lecture"
        Width="1000" Height="640" MinWidth="560" MinHeight="380"
        Background="#101116" Foreground="#E9EAEE"
        FontFamily="Segoe UI" FontSize="13"
        WindowStartupLocation="CenterOwner">
  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Theme.xaml"/>
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="Black" MouseLeftButtonUp="Video_Click">
      <Image x:Name="VideoImage" Stretch="Uniform"
             RenderOptions.BitmapScalingMode="Linear"/>
    </Border>

    <Grid Grid.Row="1" Margin="14,10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <Button x:Name="PlayPauseButton" Grid.Column="0" Content="⏸" Width="42"
              FontSize="15" Padding="0,4" Click="PlayPause_Click"/>

      <Slider x:Name="PositionSlider" Grid.Column="1" Margin="12,0"
              VerticalAlignment="Center" IsMoveToPointEnabled="True"
              Maximum="1" Foreground="#2F6BE4"
              PreviewMouseDown="Slider_SeekStart" PreviewMouseUp="Slider_SeekEnd"/>

      <TextBlock x:Name="TimeText" Grid.Column="2" VerticalAlignment="Center"
                 Foreground="#9BA0AC" Margin="0,0,14,0" Text="0:00 / 0:00"/>

      <Slider x:Name="VolumeSlider" Grid.Column="3" Width="90" Maximum="1" Value="0.8"
              VerticalAlignment="Center" Margin="0,0,14,0" IsMoveToPointEnabled="True"
              ToolTip="Volume" ValueChanged="Volume_Changed"/>

      <Button Grid.Column="4" Content="Ouvrir l'emplacement" Margin="0,0,8,0" Click="Reveal_Click"/>
      <Button Grid.Column="5" Content="Lecteur externe" Click="External_Click"/>
    </Grid>

    <!-- Découpe : marquer début/fin puis exporter l'extrait (copie de flux, instantané) -->
    <Grid Grid.Row="2" Margin="14,0,14,10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <Button Grid.Column="0" Content="⟦ Début" Click="MarkStart_Click"
              ToolTip="Marque le début de l'extrait à la position actuelle"/>
      <Button Grid.Column="1" Content="Fin ⟧" Margin="8,0,0,0" Click="MarkEnd_Click"
              ToolTip="Marque la fin de l'extrait à la position actuelle"/>
      <TextBlock x:Name="TrimText" Grid.Column="2" Margin="14,0" VerticalAlignment="Center"
                 Foreground="#9BA0AC" TextTrimming="CharacterEllipsis"
                 Text="Découpe : placez un début et une fin, puis exportez (précision ~2 s)."/>
      <Button x:Name="ExportTrimButton" Grid.Column="3" Content="Exporter l'extrait"
              IsEnabled="False" Click="ExportTrim_Click"/>
    </Grid>
  </Grid>
</Window>
