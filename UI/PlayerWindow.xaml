<Window x:Class="ScreenClipTool.UI.PlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TimeCap — Lecture"
        Width="1000" Height="640" MinWidth="560" MinHeight="380"
        Background="#101116" Foreground="#E9EAEE"
        FontFamily="Segoe UI" FontSize="13"
        WindowStartupLocation="CenterOwner">
  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Theme.xaml"/>
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="Black">
      <MediaElement x:Name="Media" LoadedBehavior="Manual" UnloadedBehavior="Stop"
                    ScrubbingEnabled="True" Stretch="Uniform"
                    MediaOpened="Media_Opened" MediaEnded="Media_Ended"
                    MediaFailed="Media_Failed" MouseLeftButtonUp="Media_Click"/>
    </Border>

    <Grid Grid.Row="1" Margin="14,10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <Button x:Name="PlayPauseButton" Grid.Column="0" Content="⏸" Width="42"
              FontSize="15" Padding="0,4" Click="PlayPause_Click"/>

      <Slider x:Name="PositionSlider" Grid.Column="1" Margin="12,0"
              VerticalAlignment="Center" IsMoveToPointEnabled="True"
              Maximum="1" Foreground="#2F6BE4"
              PreviewMouseDown="Slider_SeekStart" PreviewMouseUp="Slider_SeekEnd"
              ValueChanged="Slider_ValueChanged"/>

      <TextBlock x:Name="TimeText" Grid.Column="2" VerticalAlignment="Center"
                 Foreground="#9BA0AC" Margin="0,0,14,0" Text="0:00 / 0:00"/>

      <Button Grid.Column="3" Content="Ouvrir l'emplacement" Margin="0,0,8,0" Click="Reveal_Click"/>
      <Button Grid.Column="4" Content="Lecteur externe" Click="External_Click"/>
    </Grid>
  </Grid>
</Window>
